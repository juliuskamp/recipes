{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Recipe",
  "type": "object",
  "required": [
    "language", "title", "default_servings", "serving_unit",
    "meal_type", "tags", "version", "ingredients", "instructions"
  ],
  "properties": {
    "language": {
      "type": "string",
      "enum": ["en", "de"],
      "description": "Base language of the recipe"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "default_servings": {
      "type": "number",
      "minimum": 1
    },
    "serving_unit": {
      "type": "string",
      "minLength": 1
    },
    "prep_time_minutes": {
      "type": "number",
      "minimum": 0
    },
    "cook_time_minutes": {
      "type": "number",
      "minimum": 0
    },
    "meal_type": {
      "type": "string",
      "enum": ["breakfast", "main", "snack", "dessert", "basic"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related_recipes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "serve_with": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Recipe IDs of basic components to serve this with (e.g. pasta, rice)"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "ingredients": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "amount": {
            "type": "number",
            "minimum": 0
          },
          "unit": {
            "type": "string",
            "enum": [
              "cups", "cup", "tbsp", "tsp", "ml", "l",
              "g", "kg", "oz", "lb", "floz", "qt", "gal", "pint",
              "whole", "piece", "pieces", "pinch",
              "bunch", "clove", "cloves",
              "cube", "cubes",
              "slice", "slices", "can", "cans",
              "package", "packages", "stick", "sticks",
              "head", "heads", "sprig", "sprigs",
              "°C", "°F"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "instructions": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["section", "steps"],
            "properties": {
              "section": { "type": "string" },
              "steps": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        }
      ]
    },
    "translations": {
      "type": "object",
      "description": "Optional translations keyed by language code (e.g. 'de'). Each must include title, serving_unit, ingredients (index-based array of translated names), and instructions.",
      "additionalProperties": {
        "type": "object",
        "required": ["title", "serving_unit", "ingredients", "instructions"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "serving_unit": {
            "type": "string",
            "minLength": 1
          },
          "ingredients": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Translated ingredient names, same order as the ingredients array"
          },
          "instructions": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              },
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["section", "steps"],
                  "properties": {
                    "section": { "type": "string" },
                    "steps": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  },
                  "additionalProperties": false
                }
              }
            ]
          },
          "variants": {
            "type": "array",
            "description": "Translations for each variant, same order as the base variants array",
            "items": {
              "type": "object",
              "required": ["variant_name", "name"],
              "properties": {
                "variant_name": {
                  "type": "string",
                  "minLength": 1
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "ingredients": {
                  "type": "object",
                  "description": "Sparse map of string-integer indices to translated ingredient names"
                },
                "instructions": {
                  "oneOf": [
                    { "type": "string" },
                    {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["section", "steps"],
                        "properties": {
                          "section": { "type": "string" },
                          "steps": {
                            "type": "array",
                            "items": { "type": "string" }
                          }
                        },
                        "additionalProperties": false
                      }
                    }
                  ]
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "variants": {
      "type": "array",
      "description": "Alternative variants of the recipe. The base recipe is always the default; entries here are additional variants.",
      "items": {
        "type": "object",
        "required": ["variant_name", "name"],
        "properties": {
          "variant_name": {
            "type": "string",
            "minLength": 1,
            "description": "Short label shown on the variant selector button"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Recipe title when this variant is active"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "ingredients": {
            "type": "object",
            "description": "Sparse map of string-integer indices to ingredient override objects"
          },
          "instructions": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              },
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["section", "steps"],
                  "properties": {
                    "section": { "type": "string" },
                    "steps": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  },
                  "additionalProperties": false
                }
              }
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
