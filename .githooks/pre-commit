#!/bin/bash
set -e

# Validate all recipe JSON files against the schema
if ! node validate.js recipes/*.json; then
  echo "Recipe validation failed."
  exit 1
fi

ERRORS=0

# Check version increment for modified recipe files
MODIFIED=$(git diff --cached --name-only --diff-filter=M | grep '^recipes/.*\.json$' || true)

for file in $MODIFIED; do
  OLD_VERSION=$(git show HEAD:"$file" 2>/dev/null | node -e "let s='';process.stdin.on('data',d=>s+=d).on('end',()=>{try{console.log(JSON.parse(s).version||0)}catch{console.log(0)}})" 2>/dev/null || echo "0")
  NEW_VERSION=$(node -e "console.log(JSON.parse(require('fs').readFileSync('$file','utf8')).version||0)" 2>/dev/null || echo "0")

  if [ "$NEW_VERSION" -le "$OLD_VERSION" ]; then
    echo "ERROR: Version not incremented in $file (was $OLD_VERSION, is $NEW_VERSION)"
    ERRORS=1
  fi
done

if [ "$ERRORS" -ne 0 ]; then
  exit 1
fi

echo "All recipes valid."
